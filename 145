class Solution:
    def postorderTraversal(self, root: Optional[TreeNode]) -> List[int]:
        res,stack=[],[(root,False)]
        while stack:
            node, visited=stack.pop()
            if node:
                if visited:res.append(node.val)
                else:stack.extend([(node,True), (node.right,False),(node.left,False)])
        return res
